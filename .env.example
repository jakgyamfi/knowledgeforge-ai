# Copy to .env for local overrides. Never commit .env.
# Paths may be absolute or relative to the repository root.
# On Windows with iCloud Drive, this can be an absolute path such as:
# KF_INBOX_DIR=B:\iCloud\iCloudDrive\KnowledgeForge\Inbox
KF_INBOX_DIR=Inbox
KF_RECORDINGS_DIR=recordings
KF_TRANSCRIPTS_DIR=transcripts
KF_SUMMARIES_DIR=summaries
KF_LOG_DIR=logs
KF_DATABASE_PATH=database/knowledgeforge.db
KF_IMPORTS_DIR=imports

# Whisper model: tiny, base, small, medium, large, or turbo.
KF_WHISPER_MODEL=base
# Leave blank for automatic language detection, or use a code such as en.
KF_LANGUAGE=
# cpu works everywhere; use cuda only with a compatible PyTorch/GPU setup.
KF_DEVICE=cpu
# Polling interval for watch mode.
KF_POLL_SECONDS=5

# Web application. Keep 127.0.0.1 for local-only access.
KF_WEB_HOST=127.0.0.1
KF_WEB_PORT=8765
KF_MAX_UPLOAD_MB=250

# Optional AI organization/chat. Whisper remains local when this is enabled.
KF_AI_PROVIDER=openai
KF_AI_MODEL=gpt-5.6
KF_DEFAULT_PROJECT=My Book
OPENAI_API_KEY=

# Fully local alternative:
# KF_AI_PROVIDER=ollama
# KF_AI_MODEL=gpt-oss:20b
KF_OLLAMA_URL=http://127.0.0.1:11434
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
